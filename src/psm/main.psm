main:

; -- Calling clean_screen() --
CALL clean_screen
LOAD s4, s0  ; Capture return value from clean_screen
; -- End Call -- 

LOAD s4, 00
LOAD sA, s4  ; state = [result]
LOAD s4, 00
LOAD sB, s4  ; current_number_of_recordings = [result]

L_WHILE_START_6:
; Infinite loop detected (while 1)

; -- Calling clean_screen() --
CALL clean_screen
LOAD s4, s0  ; Capture return value from clean_screen
; -- End Call -- 

LOAD s4, sA  ; Copy 'state' for math
LOAD s5, 00
COMPARE s4, s5
JUMP NZ, L_ELSE_7
; --- IF BLOCK ---

; -- Calling print_menu() --
CALL print_menu
LOAD s4, s0  ; Capture return value from print_menu
; -- End Call -- 

INPUT s5, 01  ; read from port 01
LOAD s4, s5  ; keypad_input = [result]

L_WHILE_START_8:
LOAD s5, s4  ; Copy 'keypad_input' for math
LOAD s6, 00
COMPARE s5, s6
JUMP NZ, L_WHILE_END_8  ; Jump away if NOT equal
INPUT s5, 01  ; read from port 01
LOAD s4, s5  ; keypad_input = [result]
JUMP L_WHILE_START_8
L_WHILE_END_8:
LOAD s5, s4  ; Copy 'keypad_input' for math
LOAD s6, 00
COMPARE s5, s6
JUMP Z, L_IF_END_9
; --- IF BLOCK ---
LOAD s5, s4  ; Copy 'keypad_input' for math
LOAD s6, 11
COMPARE s5, s6
JUMP NZ, L_ELSE_10
; --- IF BLOCK ---
LOAD s5, 01
LOAD sA, s5  ; state = [result]
JUMP L_IF_END_10  ; Skip the else block

L_ELSE_10:
; --- ELSE BLOCK ---
LOAD s5, s4  ; Copy 'keypad_input' for math
LOAD s6, 12
COMPARE s5, s6
LOAD s5, 01  ; Assume True
JUMP Z, cmp_true_11        ; If Zero flag is set, they are equal!
LOAD s5, 00  ; If no jump, it was False
cmp_true_11:

L_IF_END_10:

L_IF_END_9:
JUMP L_IF_END_7  ; Skip the else block

L_ELSE_7:
; --- ELSE BLOCK ---
LOAD s4, sA  ; Copy 'state' for math
LOAD s6, 01
COMPARE s4, s6
LOAD s4, 01  ; Assume True
JUMP Z, cmp_true_12        ; If Zero flag is set, they are equal!
LOAD s4, 00  ; If no jump, it was False
cmp_true_12:

L_IF_END_7:
JUMP L_WHILE_START_6
L_WHILE_END_6:
L_main_END:
RETURN
