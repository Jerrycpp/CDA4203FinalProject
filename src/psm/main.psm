; -- SYSTEM BOOT --
LOAD sF, FF  ; Init Stack Pointer (sF)
CALL main  ; Begin execution
SYSTEM_HALT: JUMP SYSTEM_HALT
; -------------

delay_1s:
; Prolouge: Saving Callee-Saved Registers
STORE sA, (sF)  ; Push sA to stack
SUB sF, 01    ; Move SP down
STORE sB, (sF)  ; Push sB to stack
SUB sF, 01    ; Move SP down
STORE sC, (sF)  ; Push sC to stack
SUB sF, 01    ; Move SP down
STORE sD, (sF)  ; Push sD to stack
SUB sF, 01    ; Move SP down
STORE sE, (sF)  ; Push sE to stack
SUB sF, 01    ; Move SP down
LOAD s4, 00
LOAD sA, s4  ; i = [result]

L_WHILE_START_0:
LOAD s4, sA  ; Copy 'i' for math
LOAD s5, FF
COMPARE s5, s4  ; OPERANDS SWAPPED!
JUMP C, L_WHILE_END_0   ; Jump away if right < left
LOAD s5, 00
LOAD s4, s5  ; j = [result]

L_WHILE_START_1:
LOAD s5, sA  ; Copy 'i' for math
LOAD s6, FF
COMPARE s6, s5  ; OPERANDS SWAPPED!
JUMP C, L_WHILE_END_1   ; Jump away if right < left
LOAD s6, 00
LOAD s5, s6  ; k = [result]

L_WHILE_START_2:
LOAD s6, s5  ; Copy 'k' for math
LOAD s7, FF
COMPARE s7, s6  ; OPERANDS SWAPPED!
JUMP C, L_WHILE_END_2   ; Jump away if right < left
LOAD s0, s0  ; [Inline Assembly Injected]
LOAD s0, s0  ; [Inline Assembly Injected]
LOAD s0, s0  ; [Inline Assembly Injected]
LOAD s0, s0  ; [Inline Assembly Injected]
LOAD s0, s0  ; [Inline Assembly Injected]
LOAD s0, s0  ; [Inline Assembly Injected]
LOAD s6, s5  ; Copy 'k' for math
LOAD s7, 01
ADD s6, s7
LOAD s5, s6  ; k = [result]
JUMP L_WHILE_START_2
L_WHILE_END_2:
LOAD s6, s4  ; Copy 'j' for math
LOAD s7, 01
ADD s6, s7
LOAD s4, s6  ; j = [result]
JUMP L_WHILE_START_1
L_WHILE_END_1:
LOAD s5, sA  ; Copy 'i' for math
LOAD s6, 01
ADD s5, s6
LOAD sA, s5  ; i = [result]
JUMP L_WHILE_START_0
L_WHILE_END_0:
L_delay_1s_END:
; Epilouge
ADD sF, 01    ; Move SP up
FETCH sE, (sF)  ; Pop sE from stack
ADD sF, 01    ; Move SP up
FETCH sD, (sF)  ; Pop sD from stack
ADD sF, 01    ; Move SP up
FETCH sC, (sF)  ; Pop sC from stack
ADD sF, 01    ; Move SP up
FETCH sB, (sF)  ; Pop sB from stack
ADD sF, 01    ; Move SP up
FETCH sA, (sF)  ; Pop sA from stack
RETURN

delay:
; Prolouge: Saving Callee-Saved Registers
STORE sA, (sF)  ; Push sA to stack
SUB sF, 01    ; Move SP down
STORE sB, (sF)  ; Push sB to stack
SUB sF, 01    ; Move SP down
STORE sC, (sF)  ; Push sC to stack
SUB sF, 01    ; Move SP down
STORE sD, (sF)  ; Push sD to stack
SUB sF, 01    ; Move SP down
STORE sE, (sF)  ; Push sE to stack
SUB sF, 01    ; Move SP down
LOAD sA, s0  ; param 'seconds' from s0
LOAD s4, 00
LOAD sB, s4  ; i = [result]

L_WHILE_START_3:
LOAD s4, sB  ; Copy 'i' for math
LOAD s5, sA  ; Copy 'seconds' for math
COMPARE s4, s5
JUMP NC, L_WHILE_END_3  ; Jump away if left >= right

; -- Calling delay_1s() --
CALL delay_1s
LOAD s4, s0  ; Capture return value from delay_1s
; -- End Call -- 

LOAD s4, sB  ; Copy 'i' for math
LOAD s5, 01
ADD s4, s5
LOAD sB, s4  ; i = [result]
JUMP L_WHILE_START_3
L_WHILE_END_3:
L_delay_END:
; Epilouge
ADD sF, 01    ; Move SP up
FETCH sE, (sF)  ; Pop sE from stack
ADD sF, 01    ; Move SP up
FETCH sD, (sF)  ; Pop sD from stack
ADD sF, 01    ; Move SP up
FETCH sC, (sF)  ; Pop sC from stack
ADD sF, 01    ; Move SP up
FETCH sB, (sF)  ; Pop sB from stack
ADD sF, 01    ; Move SP up
FETCH sA, (sF)  ; Pop sA from stack
RETURN

clean_screen:
; Prolouge: Saving Callee-Saved Registers
STORE sA, (sF)  ; Push sA to stack
SUB sF, 01    ; Move SP down
STORE sB, (sF)  ; Push sB to stack
SUB sF, 01    ; Move SP down
STORE sC, (sF)  ; Push sC to stack
SUB sF, 01    ; Move SP down
STORE sD, (sF)  ; Push sD to stack
SUB sF, 01    ; Move SP down
STORE sE, (sF)  ; Push sE to stack
SUB sF, 01    ; Move SP down
LOAD s4, 00
OUTPUT s4, 02  ; output to port 02
LOAD s4, 00  ; output() void return
LOAD s4, 00
OUTPUT s4, 04  ; output to port 04
LOAD s4, 00  ; output() void return
LOAD s4, 00
LOAD sA, s4  ; i = [result]

L_WHILE_START_4:
LOAD s4, sA  ; Copy 'i' for math
LOAD s5, 11
COMPARE s4, s5
JUMP NC, L_WHILE_END_4  ; Jump away if left >= right
LOAD s5, 00
LOAD s4, s5  ; j = [result]

L_WHILE_START_5:
LOAD s5, s4  ; Copy 'j' for math
LOAD s6, 3C
COMPARE s5, s6
JUMP NC, L_WHILE_END_5  ; Jump away if left >= right

; -- print(" ") on port 01 --
LOAD s5, 20  ; ' '
OUTPUT s5, 01
; -- end print --

LOAD s5, 00  ; print() void return
LOAD s5, s4  ; Copy 'j' for math
LOAD s6, 01
ADD s5, s6
LOAD s4, s5  ; j = [result]
JUMP L_WHILE_START_5
L_WHILE_END_5:
LOAD s5, sA  ; Copy 'i' for math
LOAD s6, 01
ADD s5, s6
LOAD sA, s5  ; i = [result]
JUMP L_WHILE_START_4
L_WHILE_END_4:
L_clean_screen_END:
; Epilouge
ADD sF, 01    ; Move SP up
FETCH sE, (sF)  ; Pop sE from stack
ADD sF, 01    ; Move SP up
FETCH sD, (sF)  ; Pop sD from stack
ADD sF, 01    ; Move SP up
FETCH sC, (sF)  ; Pop sC from stack
ADD sF, 01    ; Move SP up
FETCH sB, (sF)  ; Pop sB from stack
ADD sF, 01    ; Move SP up
FETCH sA, (sF)  ; Pop sA from stack
RETURN

